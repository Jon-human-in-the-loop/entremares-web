# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev
TO_EMAIL=info@entremares.pt

# ─── Ifthenpay Payments ───────────────────────────────────────────────────────
# Get these from your Ifthenpay backoffice after account activation.
# Contact: suporte@ifthenpay.com | 808 222 777
IFTHENPAY_MBWAY_KEY=ZZZ-000000
IFTHENPAY_MB_KEY=ZZZ-000000
# Set this in your Ifthenpay backoffice → Callback → Anti-phishing key
IFTHENPAY_ANTI_PHISHING_KEY=your_secret_anti_phishing_key

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://entremares.pt
